        {
            "review_id": "226257366",
            "steam_id": "76561199741733257",
            "playtime_minutes": 80094,
            "voted_up": true,
            "votes_up": 0,
            "weighted_score": 0.5,
            "steam_purchase": true,
            "review_text": "I have spent 1334 hours playing this game. \r\n1. Choose Tetonic. \r\n2. Dedicate 1334 hours of your life. \r\n3. Spam Ritterbruders and destroy the Lithuanian pagans. \r\n4. Get divorced."
