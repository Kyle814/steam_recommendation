        {
            "review_id": "226016640",
            "steam_id": "76561198041685011",
            "playtime_minutes": 74,
            "voted_up": false,
            "votes_up": 1,
            "weighted_score": 0.5,
            "steam_purchase": true,
            "review_text": "Non-Nintendo Mario Party clone (derogatory). The mini-games were uninspiring and you know this game is bad when the most hype moment during our session was when 2 people were duking it out in a game of Pong from ♥♥♥♥♥♥♥ 1972."
        },
        {
            "review_id": "225997909",
            "steam_id": "76561199275240298",
            "playtime_minutes": 230,
            "voted_up": true,
            "votes_up": 0,
            "weighted_score": 0.5,
            "steam_purchase": true,
            "review_text": "The game is a solid 8/10, bunch of minigames, bunch of items and ways to mow your way through your friends in order to win. \r\n\r\nBut please, whatever you do, make sure you buy this game with friends who ACTUALLY WANT TO PLAY these kind of games. Otherwise you've wasted your time and dissapointed yourself. \r\n\r\nOnly exception might be if you can find people on discord to play with.\r\n"
        },
