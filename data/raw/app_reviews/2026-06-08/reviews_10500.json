        {
            "review_id": "226982278",
            "steam_id": "76561199289442192",
            "playtime_minutes": 26306,
            "voted_up": false,
            "votes_up": 0,
            "weighted_score": 0.5,
            "steam_purchase": true,
            "review_text": "Full of bugs - cannot finish the main campaign - crashes, fortifications are unfixable, armies on ships are lost, crashes during turns - Creative Assembly have done nothing to fix this - don't waste your money on Total War - it's been destroyed by the developers."
        },
        {
            "review_id": "226583571",
            "steam_id": "76561198051070083",
            "playtime_minutes": 12499,
            "voted_up": true,
            "votes_up": 0,
            "weighted_score": 0.5,
            "steam_purchase": true,
            "review_text": "We’re in desperate need of an Empire sequel. From the simplistic but fun economic and government management system to the endlessly fun battle and army control mechanics, Empire remains my favorite TW game even over a decade later. \r\nI’d pay $80+ for a new Empire game with more regions, more empires across the world, and larger battle sizes (5-6x times the size they are now, with the ability to manage several different engagements at once across one battlefield).  \r\n"
        },
        {
            "review_id": "226538069",
            "steam_id": "76561198253445785",
            "playtime_minutes": 15077,
            "voted_up": true,
            "votes_up": 0,
            "weighted_score": 0.5,
            "steam_purchase": true,
            "review_text": "More than 15 years later and this game is still my go to RTS game set in the 18th century setting. Can't go wrong with this game if you like to see some quick musket to musket action."
        },
