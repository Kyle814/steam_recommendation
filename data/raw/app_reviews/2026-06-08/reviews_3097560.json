        {
            "review_id": "225608983",
            "steam_id": "76561198370201073",
            "playtime_minutes": 1245,
            "voted_up": true,
            "votes_up": 0,
            "weighted_score": 0.5,
            "steam_purchase": true,
            "review_text": "The game itself is fun, however it's to this day filled with hackers/cheaters and once in a while - when the match is about to start, it suddenly crashes and I lose my points, and it counts as a loss as well (when I check the stats later). Please fix this problem!\n"
